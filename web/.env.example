# Copy to .env and fill in real values for local development.
# The app fails fast at startup with a clear error if a required var is missing.

# Base URL of the Strapi CMS API (required).
CMS_BASE_URL=http://localhost:1337

# Timeout, in milliseconds, for outbound requests to the CMS (optional, default 5000).
CMS_REQUEST_TIMEOUT_MS=5000

# Secret used to sign/encrypt member session cookies (required).
# Generate one locally, e.g.: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string
