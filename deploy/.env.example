# Production environment template (sgim-0lt.6).
#
# Copy to `.env` NEXT TO docker-compose.yml on the server, fill in freshly
# generated values, and lock it down:
#     chmod 600 .env && chown root:root .env
#
# This file is a template only — never put real production values in git.
# Generate every secret fresh; the dev values in cms/.env.example must NOT be
# reused in production.
#
#     openssl rand -base64 32      # one secret
#     openssl rand -base64 32 | tr -d '\n' | head -c 32   # fixed length

# ---- deployment ----
# GHCR namespace the CI images are published under (the repo owner).
GHCR_OWNER=khebbie
# Deploy an exact build: the commit SHA CI tagged. `latest` is convenient but
# makes rollback ambiguous — pin a SHA for real deploys.
IMAGE_TAG=latest

# ---- public origins ----
# The site's canonical public origin. adapter-node rejects form POSTs whose
# Origin does not match, so a wrong value breaks login and the duty forms.
# Staging: https://sgim.khebbie.dk   Production: https://sgim.dk
WEB_ORIGIN=https://sgim.khebbie.dk
# Public URL of the Strapi admin panel (the host the edge proxies to the CMS).
CMS_PUBLIC_URL=https://admin.sgim.khebbie.dk

# ---- database ----
DATABASE_NAME=sgim
DATABASE_USERNAME=sgim
# Generate a strong one; it is never typed by a human.
DATABASE_PASSWORD=CHANGE_ME

# ---- Strapi secrets (generate all of these) ----
# Comma-separated list of at least one key.
APP_KEYS=CHANGE_ME,CHANGE_ME
API_TOKEN_SALT=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
# Changing ENCRYPTION_KEY or the JWT secrets later invalidates existing admin
# sessions and tokens — plan rotation deliberately.
ENCRYPTION_KEY=CHANGE_ME

# ---- website ----
SESSION_SECRET=CHANGE_ME

# ---- content import (sgim-0lt.9) ----
# Paths INSIDE the cms container (./import is mounted read-only at /app/import).
# Idempotent by slug, so these can stay set: restarts skip what already exists.
IMPORT_EVENTS_FILE=/app/import/sgim-events.json
IMPORT_CLUBS_FILE=/app/import/sgim-clubs.json

# ---- first boot only ----
# Creates the Strapi super-admin idempotently on first start. Log in, change the
# password, then blank these out and redeploy.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
