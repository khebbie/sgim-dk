{
  "contentTypeName": "event",
  "singularName": "event",
  "pluralName": "events",
  "displayName": "Event",
  "description": "Events - both single-day and multi-day events",
  "kind": "collectionType",
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Event title"
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "description": "URL-friendly slug"
    },
    "description": {
      "type": "richtext",
      "description": "Event description"
    },
    "shortDescription": {
      "type": "text",
      "description": "Short teaser/abstract for listings"
    },
    "eventType": {
      "type": "enumeration",
      "enum": ["single-day", "multi-day"],
      "default": "single-day",
      "required": true,
      "description": "Type of event"
    },
    "startDate": {
      "type": "date",
      "required": true,
      "description": "Start date of the event"
    },
    "endDate": {
      "type": "date",
      "description": "End date (for multi-day events)"
    },
    "startTime": {
      "type": "time",
      "description": "Start time (for single-day events)"
    },
    "endTime": {
      "type": "time",
      "description": "End time (for single-day events)"
    },
    "location": {
      "type": "string",
      "description": "Event location/venue"
    },
    "address": {
      "type": "text",
      "description": "Full address if different from location"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "description": "Event image/poster"
    },
    "organizer": {
      "type": "string",
      "description": "Who is organizing this event"
    },
    "targetAudience": {
      "type": "string",
      "description": "Target audience (e.g., children, youth, adults, all)"
    },
    "price": {
      "type": "string",
      "description": "Price information (e.g., Free, 50 DKK, etc.)"
    },
    "registrationRequired": {
      "type": "boolean",
      "default": false,
      "description": "Is registration required"
    },
    "registrationUrl": {
      "type": "string",
      "description": "URL for registration"
    },
    "registrationDeadline": {
      "type": "datetime",
      "description": "Registration deadline"
    },
    "maxParticipants": {
      "type": "integer",
      "description": "Maximum number of participants"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false,
      "description": "Feature this event prominently"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::club.club",
      "invertedBy": "events",
      "description": "Associated club (if any)"
    },
    "publishedAt": {
      "type": "datetime"
    },
    "createdAt": {
      "type": "datetime",
      "default": null
    },
    "updatedAt": {
      "type": "datetime",
      "default": null
    },
    "createdBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "invertedBy": "createdEvents"
    },
    "updatedBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "invertedBy": "updatedEvents"
    }
  }
}
