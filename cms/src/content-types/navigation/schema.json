{
  "contentTypeName": "navigation",
  "singularName": "navigation",
  "pluralName": "navigations",
  "displayName": "Navigation",
  "description": "Navigation menu configuration",
  "kind": "collectionType",
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Navigation menu title"
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "description": "Unique identifier for the menu"
    },
    "isPrimary": {
      "type": "boolean",
      "default": false,
      "description": "Is this the primary navigation menu"
    },
    "location": {
      "type": "enumeration",
      "enum": ["header", "footer", "sidebar", "mobile"],
      "default": "header",
      "description": "Where this navigation appears"
    },
    "publishedAt": {
      "type": "datetime"
    },
    "createdAt": {
      "type": "datetime",
      "default": null
    },
    "updatedAt": {
      "type": "datetime",
      "default": null
    },
    "createdBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "invertedBy": "createdNavigations"
    },
    "updatedBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "invertedBy": "updatedNavigations"
    }
  }
}
