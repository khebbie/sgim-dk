{
  "contentTypeName": "aktuelt",
  "singularName": "aktuelt",
  "pluralName": "aktuelt",
  "displayName": "Aktuelt",
  "description": "Front-page takeover/current highlights - singleton",
  "kind": "singleType",
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable the aktuelt takeover on the front page"
    },
    "title": {
      "type": "string",
      "description": "Aktuelt headline"
    },
    "subtitle": {
      "type": "string",
      "description": "Aktuelt subheading"
    },
    "content": {
      "type": "richtext",
      "description": "Main content for the aktuelt section"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "description": "Main image for the aktuelt section"
    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "description": "Background image (optional)"
    },
    "ctaText": {
      "type": "string",
      "description": "Call-to-action button text"
    },
    "ctaUrl": {
      "type": "string",
      "description": "Call-to-action button URL"
    },
    "ctaType": {
      "type": "enumeration",
      "enum": ["none", "internal", "external"],
      "default": "internal",
      "description": "Type of CTA link"
    },
    "startDate": {
      "type": "datetime",
      "description": "When this aktuelt should start displaying (leave empty for immediate)"
    },
    "endDate": {
      "type": "datetime",
      "description": "When this aktuelt should stop displaying (leave empty for no end date)"
    },
    "textColor": {
      "type": "enumeration",
      "enum": ["dark", "light", "auto"],
      "default": "auto",
      "description": "Text color for the aktuelt section"
    },
    "createdAt": {
      "type": "datetime",
      "default": null
    },
    "updatedAt": {
      "type": "datetime",
      "default": null
    },
    "createdBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "invertedBy": "createdAktuelt"
    },
    "updatedBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "invertedBy": "updatedAktuelt"
    }
  }
}
