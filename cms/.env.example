# Copy this file to .env and fill in every value before running the app.
# The app fails fast at boot (see src/config/env.ts) if any required
# variable below is missing or malformed — there are no silent defaults
# for secrets or database credentials.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Optional — default 0.0.0.0
HOST=0.0.0.0
# Optional — default 1337
PORT=1337

# ---------------------------------------------------------------------------
# Secrets (required)
# ---------------------------------------------------------------------------
# Comma-separated list of at least one key, used to sign admin session
# cookies. Generate fresh values for every environment, e.g.:
#   node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=replace-with-generated-key-1,replace-with-generated-key-2
API_TOKEN_SALT=replace-with-generated-secret
ADMIN_JWT_SECRET=replace-with-generated-secret
JWT_SECRET=replace-with-generated-secret
TRANSFER_TOKEN_SALT=replace-with-generated-secret
ENCRYPTION_KEY=replace-with-generated-secret

# ---------------------------------------------------------------------------
# Bootstrap Admin (optional — for automatic admin user creation)
# ---------------------------------------------------------------------------
# If BOTH are set, a super-admin user will be automatically created on first
# start (idempotent: only created if it doesn't exist).
# If NEITHER is set, no admin is auto-created.
# If ONLY ONE is set, the app will fail fast at boot.
# Generate strong credentials for production. Do NOT commit real values.
# BOOTSTRAP_ADMIN_EMAIL=admin@sgim.dk
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

# ---------------------------------------------------------------------------
# Database (PostgreSQL — required)
# ---------------------------------------------------------------------------
# DATABASE_HOST/PORT/SSL/SCHEMA/POOL_* are optional and default to the
# values below; DATABASE_NAME/USERNAME/PASSWORD are required.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=sgim
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_SCHEMA=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000
